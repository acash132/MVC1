@Model MVCFirst.Models.StudentModel1

@{
    ViewBag.Title = "List Student";
}

<h2>Student List</h2>

<table class="table">
    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Age</th>
        <th>Email</th>
        <th>Enrollment Date</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.StudentId</td>
            <td>@item.StudentName</td>
            <td>@item.Age</td>
            <td>@item.Email</td>
            <td>@item.EnrollmentDate.ToShortDateString()</td>
        </tr>
    }
</table>